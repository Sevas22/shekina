# Base de datos — obligatorio en local y en Vercel (Settings → Environment Variables).
# Vercel: añade DATABASE_URL para Production y Preview; si no, el build falla en migrate deploy.
# Producción / Vercel: PostgreSQL (Neon, Supabase, etc.), ej.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.aws.neon.tech/neondb?sslmode=require"
# Local con Postgres (Docker): postgresql://postgres:postgres@localhost:5432/shekina
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-por-secreto-largo-y-aleatorio"

# Admin inicial (solo registro en BD vía seed; el login usa email + contraseña del usuario admin)
# Opcional: forzar email del seed
# ADMIN_SEED_EMAIL="admin@shekina.local"
# ADMIN_SEED_PASSWORD="cambiar-en-produccion"

# Subida de imágenes en producción (Vercel Blob) — opcional
# BLOB_READ_WRITE_TOKEN=""
